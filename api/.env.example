# ── AWFLMETA Backend Environment Variables ────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your real .env to GitHub.

# GitHub Personal Access Token (needs repo + contents read/write scope)
GITHUB_TOKEN=ghp_REPLACE_WITH_YOUR_TOKEN

# GitHub repo details
GITHUB_OWNER=aedtpworldawfl
GITHUB_REPO=wiki

# JWT secret — use any long random string
JWT_SECRET=replace_this_with_a_long_random_secret_string

# Server port
PORT=3000

# Allowed CORS origin (your GitHub Pages URL)
FRONTEND_ORIGIN=https://aedtpworldawfl.github.io
